# Pick ONE provider. If both are set, ANTHROPIC_API_KEY wins unless you set LLM_PROVIDER explicitly.

# Anthropic — get a key from console.anthropic.com -> Settings -> API Keys
ANTHROPIC_API_KEY=

# Gemini — get a real API key from aistudio.google.com (starts with AIzaSy...), NOT an OAuth token
GEMINI_API_KEY=

# Custom — any OpenAI-compatible router/proxy (e.g. OpenRouter-style aggregators)
CUSTOM_API_KEY=
CUSTOM_BASE_URL=
CUSTOM_MODEL=

# Optional: force which provider to use ("anthropic", "gemini", or "custom") if multiple keys are set
# LLM_PROVIDER=

PORT=4174
